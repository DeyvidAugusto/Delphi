unit Form;

interface

uses
  Windows, Messages, SysUtils, Variants, Classes, Graphics, Controls, Forms,
  Dialogs, StdCtrls, Carro, Aviao, Barco;

type
  TForm1 = class(TForm)
    CarroCheckBox: TRadioButton;
    AviaoCheckBox: TRadioButton;
    BarcoCheckBox: TRadioButton;
    Mover: TButton;
    Parar: TButton;
    Info: TButton;
    procedure MoverClick(Sender: TObject);
    procedure PararClick(Sender: TObject);
    procedure FormCreate(Sender: TObject);
    procedure InfoClick(Sender: TObject);
  private
    Porche: TCarro;
    Boing: TAviao;
    Navio: TBarco;
  public
  end;

var
  Form1: TForm1;

implementation

{$R *.dfm}


procedure TForm1.FormCreate(Sender: TObject);
begin
  Porche := TCarro.Create;
  Boing := TAviao.Create;
  Navio := TBarco.Create;
end;

procedure TForm1.InfoClick(Sender: TObject);
begin
  if CarroCheckBox.Checked then
    Porche.info(self);
  if AviaoCheckBox.Checked then
    Boing.info(self);
  if BarcoCheckBox.Checked then
    Navio.info(self);
end;

procedure TForm1.MoverClick(Sender: TObject);
begin
  if CarroCheckBox.Checked then
    Porche.Mover('Porche');
  if AviaoCheckBox.Checked then
    Boing.Mover('Boing');
  if BarcoCheckBox.Checked then
    Navio.Mover('Navio');


end;

procedure TForm1.PararClick(Sender: TObject);
begin
  if CarroCheckBox.Checked then
    Porche.Parar('Porche');
  if AviaoCheckBox.Checked then
    Boing.Parar('Boing');
  if BarcoCheckBox.Checked then
    Navio.Parar('Navio');

end;

end.
