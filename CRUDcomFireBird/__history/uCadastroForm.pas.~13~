unit uCadastroForm;

interface

uses
  Windows, Messages, SysUtils, Variants, Classes, Graphics, Controls, Forms,
  Dialogs, Mask, StdCtrls, FMTBcd, DB, SqlExpr, uCadastroController;

type
  TForm2 = class(TForm)
    EdtID: TEdit;
    Label1: TLabel;
    LbNome: TLabel;
    EdtNome: TEdit;
    LbCPF: TLabel;
    LbTelefone: TLabel;
    LbNascimento: TLabel;
    Label2: TLabel;
    CbEstadoCivil: TComboBox;
    EdtEndereco: TEdit;
    LbEndereco: TLabel;
    BntIncluir: TButton;
    BntCancelar: TButton;
    MEdtCPF: TMaskEdit;
    MEdtTelefone: TMaskEdit;
    MEdtNascimento: TMaskEdit;
    SQLQueryID: TSQLQuery;
    procedure ValidarID(Sender: TObject);
    procedure EdtIDKeyPress(Sender: TObject; var Key: Char);
    procedure FormCreate(Sender: TObject);
  private
    function verificarID(AID : integer): boolean;
  public
    { Public declarations }
  end;

var
  Form2: TForm2;

implementation

{$R *.dfm}
uses
   uMainForm;

{ TForm2 }

procedure TForm2.EdtIDKeyPress(Sender: TObject; var Key: Char);
begin
   if Key = #13 then
      ValidarID(sender);
end;

procedure TForm2.FormCreate(Sender: TObject);
begin
   SQLQueryID.SQLConnection := Form1.SQLConnectionDb;
   SQLQueryID.SQL.Text := 'SELECT MAX(ID) AS ultimo_id FROM USUARIOS';
   SQLQueryID.Open;
   EdtID.Text := IntToStr(SQLQueryID.fieldbyname('ultimo_id').asinteger + 1);
   SQLQueryID.Close;
end;

procedure TForm2.ValidarID(Sender: TObject);
var
   ID : integer;
begin
   try
      ID := StrToInt(EdtID.Text);
      if verificarID(ID) then
      begin
         EdtID.Enabled := False;
         EdtNome.Enabled := True;
         EdtEndereco.Enabled := True;
         MEdtCPF.Enabled := True;
         MEdtNascimento.Enabled := True;
         MEdtTelefone.Enabled := True;
         CbEstadoCivil.Enabled := True;
      end;
   except
      on E: Exception do
      ShowMessage('Erro: ' + E.Message + #13 + 'Adicione um ID Valido');
   end;
end;

function TForm2.verificarID(AID : integer): boolean;
begin
   Result := False;
   SQLQueryID.Close;
   SQLQueryID.SQLConnection := Form1.SQLConnectionDb;
   SQLQueryID.DataSource    := Form1.DataSourceDb;

   SQLQueryID.SQL.Text := 'SELECT COUNT(*) FROM USUARIOS WHERE id = :id';
   SQLQueryID.ParamByName('id').AsInteger := AID;
   SQLQueryID.Open;
   Result := not SQLQueryID.IsEmpty;
   SQLQueryID.Close;
end;

end.
