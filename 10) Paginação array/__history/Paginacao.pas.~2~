unit Paginacao;

interface

uses
  Windows, Messages, SysUtils, Variants, Classes, Graphics, Controls, Forms,
  Dialogs, StdCtrls, StrUtils;

type
  TForm1 = class(TForm)
    Label1: TLabel;
    EdtTamanhoArray: TEdit;
    Label2: TLabel;
    EdtQtdItens: TEdit;
    BtnDecrescente: TButton;
    BtnCrescente: TButton;
    MemoNumeros: TMemo;
    BtnAnterior: TButton;
    BtnProximo: TButton;
    Label3: TLabel;
    BtnSair: TButton;
    BtnGerarLista: TButton;
    procedure BtnGerarListaClick(Sender: TObject);
  private
    TamanhoArray: integer;
    QtdItens : integer;
    ArrayAleatorio : array of string;
  public
  end;

var
  Form1: TForm1;

implementation

{$R *.dfm}


procedure TForm1.BtnGerarListaClick(Sender: TObject);
var
  I: integer;
  NumAleatorio : string;
begin
  TamanhoArray := strtoint(EdtTamanhoArray.Text);
  QtdItens := strtoint(EdtQtdItens.Text);
  Randomize;

  SetLength(ArrayAleatorio, TamanhoArray);

  I := 0;
  repeat
    NumAleatorio := inttostr(Random(TamanhoArray));
    if not MatchStr(NumAleatorio, ArrayAleatorio) then
    begin
      ArrayAleatorio[I] := NumAleatorio;
      I := I + 1;
    end;
  until Length(ArrayAleatorio) = TamanhoArray;

  for I := 0 to QtdItens do
  begin
    MemoNumeros.Lines.Clear;
    MemoNumeros.Lines.Add(ArrayAleatorio[I]);
  end;

    


  {TamanhoArrayPaginado := round(TamanhoArray / QtdItens);
  SetLength(ArrayPaginado, TamanhoArrayPaginado);
  for I := 0 to Length(ArrayPaginado) - 1 do
  begin
      SetLength(ArrayPaginado[I], QtdItens);
  end;

  for I := Low(ArrayPaginado) to High(ArrayPaginado) do
  begin
    for Y := Low(ArrayPaginado[I]) to High(ArrayPaginado[I]) do
    begin
      ArrayPaginado[I][Y] := ArrayAleatorio[Y];
    end;
  end;}

end;

end.
