unit Ordenador;

interface
uses
  Classes, SysUtils;

type
  TOrdenador = class
  public
    class function Ordenar(Lista: TStringList;
                           Crescente: boolean): TStringList;
  end;

implementation

class function TOrdenador.Ordenar(Lista: TStringList;
                                  Crescente: boolean): TStringList;
var
  I, J: integer;
  Temp: string;
  Trocar: boolean;
begin
  Result := TStringList.Create;

  for I := 0 to Lista.Count - 1 do
    Result.Add(Lista[I]);

  for I := 0 to Result.Count - 2 do
  begin
    for J := 0 to Result.Count - 2 - I do
    begin
      if Crescente then
        Trocar := StrToInt(Result[J]) > StrToInt(Result[J + 1])
      else
        Trocar := StrToInt(Result[J]) < StrToInt(Result[J + 1]);

      if Trocar then
      begin
        Temp := Result[J];
        Result[J] := Result[J + 1];
        Result[J + 1] := Temp;
      end;
    end;
  end;
end;

end.
