unit Form;

interface
uses
  Windows, Messages, SysUtils, Classes, Graphics, Controls, Forms,
  Dialogs, StdCtrls, Paginador, GeradorLista;

type
  TForm1 = class(TForm)
    Label1: TLabel;
    EdtTamanhoArray: TEdit;
    Label2: TLabel;
    EdtQtdItens: TEdit;
    MemoNumeros: TMemo;
    BtnAnterior: TButton;
    BtnProximo: TButton;
    QtdPag: TLabel;
    BtnSair: TButton;
    BtnGerarLista: TButton;
    procedure BtnGerarListaClick(Sender: TObject);
    procedure BtnProximoClick(Sender: TObject);
    procedure BtnAnteriorClick(Sender: TObject);
    procedure FormDestroy(Sender: TObject);
  private
    FLista: TStringList;
    FPaginador: TPaginador;
    procedure ExibirPagina(Pagina: TStringList);
    procedure AtualizarLabel;
  end;

var
  Form1: TForm1;

implementation
{$R *.dfm}

procedure TForm1.FormDestroy(Sender: TObject);
begin
  FreeAndNil(FPaginador);
  FreeAndNil(FLista);
end;

procedure TForm1.BtnGerarListaClick(Sender: TObject);
var
  TamanhoArray, QtdItens: integer;
  PaginaInicial: TStringList;
begin
  TamanhoArray := StrToInt(EdtTamanhoArray.Text);
  QtdItens     := StrToInt(EdtQtdItens.Text);

  FreeAndNil(FPaginador);
  FreeAndNil(FLista);

  FLista := TGeradorLista.GerarAleatorio(TamanhoArray);

  FPaginador := TPaginador.Create(QtdItens);
  FPaginador.CarregarLista(FLista);

  PaginaInicial := FPaginador.ObterPaginaAtual;
  try
    ExibirPagina(PaginaInicial);
    AtualizarLabel;
  finally
    PaginaInicial.Free;
  end;
end;

procedure TForm1.BtnProximoClick(Sender: TObject);
var
  Pagina: TStringList;
begin
  if FPaginador = nil then Exit;
  try
    Pagina := FPaginador.ProximaPagina;
    try
      ExibirPagina(Pagina);
      AtualizarLabel;
    finally
      Pagina.Free;
    end;
  except
    on E: Exception do
      ShowMessage(E.Message);
  end;
end;

procedure TForm1.BtnAnteriorClick(Sender: TObject);
var
  Pagina: TStringList;
begin
  if FPaginador = nil then Exit;
  try
    Pagina := FPaginador.PaginaAnterior;
    try
      ExibirPagina(Pagina);
      AtualizarLabel;
    finally
      Pagina.Free;
    end;
  except
    on E: Exception do
      ShowMessage(E.Message);
  end;
end;

procedure TForm1.ExibirPagina(Pagina: TStringList);
var
  I: integer;
begin
  MemoNumeros.Lines.Clear;
  for I := 0 to Pagina.Count - 1 do
    MemoNumeros.Lines.Add(Pagina[I]);
end;

procedure TForm1.AtualizarLabel;
begin
  QtdPag.Caption := 'Página ' + IntToStr(FPaginador.PaginaCorrente) +
                    ' de '    + IntToStr(FPaginador.TotalPaginas);
end;

end.
