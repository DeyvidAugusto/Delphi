unit Cronometro;

interface
uses
  Windows, SysUtils;

type
  TCronometro = class
  private
    FInicio: Int64;
    FFrequencia: Int64;
  public
    constructor Create;
    procedure Iniciar;
    function TempoDecorrido: string; // retorna em ms formatado
  end;

implementation

constructor TCronometro.Create;
begin
  inherited;
  QueryPerformanceFrequency(FFrequencia);
end;

procedure TCronometro.Iniciar;
begin
  QueryPerformanceCounter(FInicio);
end;

function TCronometro.TempoDecorrido: string;
var
  Fim: Int64;
  TempoMs: double;
begin
  QueryPerformanceCounter(Fim);
  TempoMs := ((Fim - FInicio) / FFrequencia) * 1000;
  Result := FormatFloat('0.000', TempoMs) + ' ms';
end;

end.
