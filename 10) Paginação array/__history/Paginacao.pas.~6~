unit Paginacao;

interface

uses
  Windows, Messages, SysUtils, Variants, Classes, Graphics, Controls, Forms,
  Dialogs, StdCtrls, StrUtils;

type
  TForm1 = class(TForm)
    Label1: TLabel;
    EdtTamanhoArray: TEdit;
    Label2: TLabel;
    EdtQtdItens: TEdit;
    BtnDecrescente: TButton;
    BtnCrescente: TButton;
    MemoNumeros: TMemo;
    BtnAnterior: TButton;
    BtnProximo: TButton;
    QtdPag: TLabel;
    BtnSair: TButton;
    BtnGerarLista: TButton;
    procedure BtnGerarListaClick(Sender: TObject);
    procedure BtnProximoClick(Sender: TObject);
    procedure BtnAnteriorClick(Sender: TObject);
  private
    TamanhoArray: integer;
    QtdItens : integer;
    ArrayAleatorio : TStringList;
    ListaPaginada : TStringList;
    NumeroPagina: integer;
    NumeroMaxPaginas : double;
    procedure RetornarPagina(out Lista: TStringList; PaginaAtual : integer);
  public
  end;

var
  Form1: TForm1;

implementation

{$R *.dfm}


procedure TForm1.BtnGerarListaClick(Sender: TObject);
var
  I: integer;
  NumAleatorio : string;
begin
  TamanhoArray := strtoint(EdtTamanhoArray.Text);
  QtdItens := strtoint(EdtQtdItens.Text);
  NumeroPagina := 0;
  Randomize;
  ArrayAleatorio := TStringList.Create;
  ListaPaginada := TStringList.Create;
  NumeroMaxPaginas := TamanhoArray/QtdItens;

  repeat
    NumAleatorio := NumAleatorio + 'a ';{inttostr(Random(TamanhoArray + 100))};
    if ArrayAleatorio.IndexOf(NumAleatorio) = -1 then
    begin
      ArrayAleatorio.add(NumAleatorio);
    end;
  until ArrayAleatorio.Count = TamanhoArray;

  MemoNumeros.Lines.Clear;
  for I := 0 to QtdItens - 1 do
  begin
    MemoNumeros.Lines.Add(ArrayAleatorio[I]);
  end;

end;

{ARRUMANDO}
procedure TForm1.BtnAnteriorClick(Sender: TObject);
var
  I: Integer;
begin
  try
    if NumeroPagina = 0 then
    begin
      raise Exception.Create('Já na primeira pagina');
      exit;
    end;
    NumeroPagina := NumeroPagina - 1;
    Form1.RetornarPagina(ListaPaginada, NumeroPagina);
    MemoNumeros.Clear;
    for I := 0 to ListaPaginada.Count - 1 do
      MemoNumeros.Lines.add(ListaPaginada[I]);

  finally
    ListaPaginada.Free;
  end;

end;


procedure TForm1.BtnProximoClick(Sender: TObject);
var
  I : integer;
begin
  try

    if NumeroPagina = NumeroMaxPaginas then
      begin
        raise Exception.Create('Já na Ultima pagina');
        exit;
      end;
    NumeroPagina := NumeroPagina + 1;
    Form1.RetornarPagina(ListaPaginada, NumeroPagina);

    MemoNumeros.Clear;
    for I := 0 to ListaPaginada.Count - 1 do
      MemoNumeros.Lines.add(ListaPaginada[I]);

  finally
    ListaPaginada.Free;
  end;
end;


procedure TForm1.RetornarPagina(out Lista: TStringList; PaginaAtual : integer);
var
  I, Posicao, ProxPosicao : integer;
begin
  try
  Lista := TStringList.Create;
  Posicao := PaginaAtual * QtdItens;
  ProxPosicao := Posicao + (QtdItens - 1);
  Lista.Clear;
  for I := Posicao to ProxPosicao do
    begin
      Lista.add(ArrayAleatorio[Posicao]);
      inc(Posicao);
    end;

  finally
    ;
  end;


end;


end.
