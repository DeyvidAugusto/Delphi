unit Paginador;

interface

uses
    Windows, Messages, SysUtils, Variants, Classes, Graphics, Controls, Forms,
    Dialogs, StdCtrls, StrUtils, Math;


type
  TPaginador = class
    private
      FLista : TStringList;
      FItensPorPagina : integer;
      FPaginaAtual : integer;
    public
      constructor Create(ItensPorPagina: integer);
      destructor Destroy; override;
      procedure CarregarLista(Lista: TStringList);
      function ProximaPagina: TStringList;
      function PaginaAnterior: TStringList;
      function PaginaAtual: TStringList;
      function TotalPaginas: integer;
      property PaginaCorrente: integer read FPaginaAtual;
  end;

implementation

end.
