unit Ordenador;

interface
uses
  Classes, SysUtils, Windows, ArrayHelper;

type
  TintArray = TMyIntArray;
  TOrdenador = class
  private
    class procedure MoverItem(var a: TintArray; index, value, count: integer); static;
  public
    class function OrdenarArray(a: TintArray): TintArray;
  end;

implementation

class function TOrdenador.OrdenarArray(a: TintArray): TintArray;
var
   aux: TintArray;
   i, x, count: integer;
begin
   SetLength(aux, Length(a));
   x := 0;
   count := 0;

   for i := 0 to high(a) do
   begin
      while (x > 0) and (a[i] < aux[x]) do
         dec(x);

      while (x < count) and (a[i] > aux[x]) do
         inc(x);

      MoverItem(aux, x, a[i], count);
      Inc(count);
   end;

   a := aux;
end;

class procedure TOrdenador.MoverItem(var a: TintArray; index, value, count: integer);
begin
   if index < count then
      move(a[index], a[index + 1], (count - index) * sizeOf(integer));

   a[index] := value;
end;

end.
