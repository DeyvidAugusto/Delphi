unit ArrayHelper;

interface
type
   TMyIntArray = array of integer;
   TarrayHelper = class
      TintArray : TMyIntArray;
      public
         class procedure insert(var a: TintArray; index, value: integer);
   end;
implementation

class procedure TarrayHelper.insert(var a: TintArray; index, value: integer);
var
   count: integer;
begin
   count := length(a);

   setLength(a, count + 1); {}

   if index < count then
      move(a[index], a[index + 1], (count - index) * sizeOf(integer));

   a[index] := value;
end;

end.
