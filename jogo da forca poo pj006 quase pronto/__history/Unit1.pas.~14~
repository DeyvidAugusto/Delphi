unit Unit1;

interface

uses
   Windows, Messages, SysUtils, Variants,
   Classes, Graphics, Controls, Forms, Dialogs,
   Unit3, StdCtrls;

type
   TForm1 = class(TForm)
    Button1: TButton;
    Button2: TButton;
    Display: TLabel;
    Memo1: TMemo;
    Label1: TLabel;
    Label2: TLabel;
    procedure FormCreate(Sender: TObject);
    procedure Button1Click(Sender: TObject);
    procedure FormDestroy(Sender: TObject);
    procedure Button2Click(Sender: TObject);
   private
      JogoForca: TJogoForca;
   public
   end;

var
   Form1: TForm1;

implementation

{$R *.dfm}

procedure TForm1.FormCreate(Sender: TObject);
begin
   JogoForca := nil;

end;

procedure TForm1.Button1Click(Sender: TObject);
begin
   JogoForca := TJogoForca.Create(
      JogoForca.GerarPalavra(),
      strtoint(InputBox('Digite a Quantidade de Jogadores', 'Quantidade', ''))
      );

   Display.Caption := JogoForca.Display;
end;

procedure TForm1.Button2Click(Sender: TObject);
var
   Letra: string;
   ListaEstatistica: TStringList;
  I: Integer;
begin
   Letra := InputBox('Informe uma letra ' + JogoForca.JogadorAtual, 'Letra', '');
   ListaEstatistica := TStringList.Create;
   
   try
     JogoForca.GetEstatisticas(ListaEstatistica);
   

   if Letra = '' then
      raise Exception.Create('Um letra deve ser informada.');

   JogoForca.Jogar(Letra[1]);

   Display.Caption := JogoForca.Display;

   Label1.Caption := JogoForca.GetLetrasUtilizadas;
   
   for I := 0 to ListaEstatistica.Count - 1 do
   begin
      Memo1.Lines.Add(ListaEstatistica[I])
   end;
   if JogoForca.GameOver then
      ShowMessage('Fim de jogo!'#13#13'Vencedor: ' + JogoForca.GetNomeVencedor);
   finally
     ListaEstatistica.Free;
   end;
end;

procedure TForm1.FormDestroy(Sender: TObject);
begin
   if JogoForca <> nil then
      Freeandnil(JogoForca);
end;


end.
