unit EditValidador;

interface

uses
  SysUtils, Classes, Controls, StdCtrls;

type
  TCustomEdit = class(TEdit)
  private
    { Private declarations }
    FisCNPJ: boolean;
    procedure KeyPressInteiro(Sender: TObject; var Key: Char);
  protected
    { Protected declarations }
  public
    constructor Create(AOwner: TComponent);
  published
    property isCPNJ : boolean read FisCNPJ write FisCNPJ;
  end;

procedure Register;

implementation

procedure Register;
begin
  RegisterComponents('Samples', [TCustomEdit]);
end;

procedure TCustomEdit.KeyPressInteiro(Sender: TObject; var Key: Char);
begin
   if not (Key in ['0'..'9', #8]) then
      Key := #0;
end;

constructor TCustomEdit.Create(AOwner: TComponent);
begin
  inherited Create(AOwner);
  Text := 'Componente Edit Customizado';
end;

end.
