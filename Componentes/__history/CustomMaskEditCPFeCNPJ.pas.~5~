unit CustomMaskEditCPFeCNPJ;

interface

uses
  SysUtils, Classes, Controls, StdCtrls, Mask;

type
  TCustomMaskEditCPFeCNPJ = class(TCustomMaskEdit)
  private

  protected
    { Protected declarations }
  public
    constructor Create(AOwner: TComponent); override;
  published
    { Published declarations }
    procedure KeyPressInteiro(Sender: TObject; var Key: Char);
  end;

procedure Register;

implementation


procedure TCustomMaskEditCPFeCNPJ.KeyPressInteiro(Sender: TObject; var Key: Char);
begin
   if not (Key in ['0'..'9', #8]) then
      Key := #0;
end;

constructor TCustomMaskEditCPFeCNPJ.Create(AOwner: TComponent);
begin
  inherited Create(AOwner);
  Text := 'Componente Edit Customizado';
end;


procedure Register;
begin
  RegisterComponents('Delphi Projects | Delphi Files', [TCustomMaskEditCPFeCNPJ]);
end;

end.
