     begin
       ListaPalavras.LoadFromFile('C:\Users\pjr006\OneDrive\Desktop (ATEN«√O !!! Amanh„ esta pasta ser· deletada, n„o sincronizar pastas do Usu·rio)\jogo da forca poo\jogo da forca poo pj006\Palavras_Aleatorias.txt');
       if ListaPalavras.Count > 0 then
