unit Ordenador;

interface
uses
  Classes, SysUtils, Windows;

type
  TOrdenador = class
  private
    class procedure QuickSort(Lista: TStringList; Esquerda, Direita: integer; Crescente: boolean);
  public
    class function Ordenar(Lista: TStringList; Crescente: boolean): TStringList;
  end;

implementation

class procedure TOrdenador.QuickSort(Lista: TStringList; Esquerda, Direita: integer; Crescente: boolean);
var
  I, J, Pivo: integer;
  Temp: string;
begin
  I := Esquerda;
  J := Direita;
  Pivo := StrToInt(Lista[(Esquerda + Direita) div 2]);

  repeat
    if Crescente then
    begin
      while StrToInt(Lista[I]) < Pivo do Inc(I);
      while StrToInt(Lista[J]) > Pivo do Dec(J);
    end
    else
    begin
      while StrToInt(Lista[I]) > Pivo do Inc(I);
      while StrToInt(Lista[J]) < Pivo do Dec(J);
    end;

    if I <= J then
    begin
      Temp      := Lista[I];
      Lista[I]  := Lista[J];
      Lista[J]  := Temp;
      Inc(I);
      Dec(J);
    end;
  until I > J;

  if Esquerda < J then
    QuickSort(Lista, Esquerda, J, Crescente);

  if I < Direita then
    QuickSort(Lista, I, Direita, Crescente);
end;

class function TOrdenador.Ordenar(Lista: TStringList; Crescente: boolean): TStringList;
var
  Inicio, Fim: integer;
begin

  Result := TStringList.Create;
  Result.AddStrings(Lista);

  if Result.Count > 1 then
    QuickSort(Result, 0, Result.Count - 1, Crescente);
end;

end.
