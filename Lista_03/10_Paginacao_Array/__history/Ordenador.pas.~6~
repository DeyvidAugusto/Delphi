unit Ordenador;

interface
uses
  Classes, SysUtils, Windows;

type
  TintArray = array of integer;

  TOrdenador = class
  private
    class procedure QuickSort(Lista: TStringList; Esquerda, Direita: integer; Crescente: boolean);
    class procedure MoverItem(var a: TintArray; index, value, count: integer); static;
  public
    class function Ordenar(Lista: TStringList; Crescente: boolean): TStringList;
    class procedure OrdenarArray(var a: TintArray); static;
  end;

implementation

class procedure TOrdenador.QuickSort(Lista: TStringList; Esquerda, Direita: integer; Crescente: boolean);
var
  I, J, Pivo: integer;
  Temp: string;
begin
  I := Esquerda;
  J := Direita;
  Pivo := StrToInt(Lista[(Esquerda + Direita) div 2]);

  repeat
    if Crescente then
    begin
      while StrToInt(Lista[I]) < Pivo do Inc(I);
      while StrToInt(Lista[J]) > Pivo do Dec(J);
    end
    else
    begin
      while StrToInt(Lista[I]) > Pivo do Inc(I);
      while StrToInt(Lista[J]) < Pivo do Dec(J);
    end;

    if I <= J then
    begin
      Temp := Lista[I];
      Lista[I] := Lista[J];
      Lista[J] := Temp;
      Inc(I);
      Dec(J);
    end;
  until I > J;

  if Esquerda < J then
    QuickSort(Lista, Esquerda, J, Crescente);

  if I < Direita then
    QuickSort(Lista, I, Direita, Crescente);
end;

class function TOrdenador.Ordenar(Lista: TStringList; Crescente: boolean): TStringList;
var
  Inicio, Fim: integer;
begin

  Result := TStringList.Create;
  Result.AddStrings(Lista);

  if Result.Count > 1 then
    QuickSort(Result, 0, Result.Count - 1, Crescente);
end;

class procedure TOrdenador.OrdenarArray(var a: TintArray);
var
   aux: TintArray;
   i, x, count: integer;
begin
   SetLength(aux, Length(a));
   x := 0;
   count := 0;

   for i := 0 to high(a) do
   begin
      while (x > 0) and (a[i] < aux[x]) do
         dec(x);

      while (x < count) and (a[i] > aux[x]) do
         inc(x);

      MoverItem(aux, x, a[i], count);
      Inc(count);
   end;

   a := aux;
end;

class procedure TOrdenador.MoverItem(var a: TintArray; index, value, count: integer);
begin
   if index < count then
      move(a[index], a[index + 1], (count - index) * sizeOf(integer));

   a[index] := value;
end;

end.
