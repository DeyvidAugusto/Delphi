  end;
  with TabelaSalarios[2] do
  begin
    ID := 3;
    Nome := 'Antonio';
    Salario := 3409.98;
  end;
  with TabelaSalarios[3] do
  begin
    ID :=4;
    Nome := 'Ana';
    Salario := 5093.34;
  end;
  with TabelaSalarios[4] do
  begin
    ID := 5;
    Nome := 'Joana';
    Salario := 3458.54;
  end;
  with TabelaSalarios[5] do
  begin
    ID := 6;
