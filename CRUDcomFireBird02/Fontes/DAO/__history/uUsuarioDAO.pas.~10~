unit uUsuarioDAO;

interface

uses SqlExpr, DB, SimpleDS, SysUtils;

type
   TUsuarioDAO = class
      private
         FConn : TSQLConnection;
         function NovaQuery : TSQLQuery;
      public
         constructor Create(AConn : TSQLConnection);
         function ProximoID: Integer;
         function isIDDisponvel(AID: integer): boolean;
         function CarregarUsuarios: TSQLQuery;
   end;

implementation

constructor TUsuarioDAO.Create(AConn : TSQLConnection);
begin
   FConn := AConn;
end;

function TUsuarioDAO.NovaQuery: TSQLQuery;
begin
  Result := TSQLQuery.Create(nil);
  Result.SQLConnection := FConn;
end;

function TUsuarioDAO.ProximoID: integer;
var
   Q: TSQLQuery;
begin
   Q := NovaQuery;
   try
      Q.SQL.Text := 'SELECT MAX(ID) AS ultimo_id FROM USUARIOS';
      Q.Open;
      Result := Q.FieldByName('ultimo_id').AsInteger + 1;
   finally
      Q.Free;
   end;
end;

function TUsuarioDAO.isIDDisponvel(AID: Integer): boolean;
var
   Q : TSQLQuery;
begin
   Q := NovaQuery;
   try
      Q.SQL.Text := 'SELECT 1 FROM USUARIOS WHERE ID = :id';
      Q.ParamByName('id').AsInteger := AID;
      Q.Open;
      Result := Q.IsEmpty
   finally
      Q.Free;
   end;
end;

function TUsuarioDAO.CarregarUsuarios: TSQLQuery;
begin
   Result := NovaQuery;
   Result.SQL.Text := 'SELECT * FROM USUARIOS';
   Result.Open;

end;

end.
